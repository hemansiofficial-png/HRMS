  complianceType      String
  country             String       @default("IN")
  state               String?
  regulation          String
  description         String?
  requirements        Json
  thresholds          Json
  filingFrequency     String       @default("MONTHLY")
  filingDeadlines     Json
  penalties           Json
  documentsRequired   String[]
  reportsRequired     String[]
  auditFrequency      String       @default("ANNUAL")
  lastAuditDate       DateTime?
  nextAuditDate       DateTime?
  complianceOfficer   String?
  autoCalculation     Boolean      @default(true)
  integrationRequired Boolean      @default(false)
  externalSystem      String?
  isActive            Boolean      @default(true)
  effectiveFrom       DateTime     @default(now())
  effectiveTo         DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([complianceType])
  @@index([isActive])
}

model Holiday {
  id             String        @id @default(cuid())
  name           String
  date           DateTime
  description    String?
  isNational     Boolean       @default(true)
  createdAt      DateTime      @default(now())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([name, date])
  @@index([organizationId])
}

model AuditLog {
  id             String        @id @default(cuid())
  employeeId     String?
  action         String
  metadata       String?
  createdAt      DateTime      @default(now())
  changes        String?
  ipAddress      String?
  module         String
  organizationId String?
  employee       Employee?     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([organizationId])
  @@index([createdAt])
}

