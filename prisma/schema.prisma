generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String              @id @default(cuid())
  name                 String
  email                String              @unique
  password             String
  role                 Role                @default(EMPLOYEE)
  createdAt            DateTime            @default(now())
  isActive             Boolean             @default(true)
  lastLoginAt          DateTime?
  phone                String?
  updatedAt            DateTime            @updatedAt
  organizationId       String?
  announcements        Announcement[]
  managedDept          Department[]        @relation("DepartmentManager")
  managedTeam          Employee[]          @relation("Manager")
  employee             Employee?
  assignedGoals        Goal[]              @relation("GoalCreator")
  interviewsScheduled  Interview[]         @relation("Interviewer")
  approvedLeaves       LeaveRequest[]      @relation("LeaveApprover")
  notifications        Notification[]
  createdReviews       PerformanceReview[] @relation("Reviewer")
  approvedResignations Resignation[]       @relation("ResignationApprover")
  surveyCreated        Survey[]
  assignedTasks        Task[]              @relation("TaskAssignee")
  createdTasks         Task[]              @relation("TaskCreator")
  organization         Organization?       @relation(fields: [organizationId], references: [id])
}

model Department {
  id             String        @id @default(cuid())
  name           String        @unique
  description    String?
  managerId      String?
  budget         Decimal?      @db.Decimal(12, 2)
  createdAt      DateTime      @default(now())
  organizationId String?
  manager        User?         @relation("DepartmentManager", fields: [managerId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  employees      Employee[]
  jobPostings    JobPosting[]

  @@index([organizationId])
}

model Employee {
  id                        String                     @id @default(cuid())
  userId                    String                     @unique
  employeeCode              String                     @unique
  departmentId              String
  designation               String
  phone                     String
  address                   String
  joiningDate               DateTime
  salary                    Decimal                    @db.Decimal(12, 2)
  status                    EmploymentStatus           @default(ACTIVE)
  photoUrl                  String?
  city                      String?
  country                   String?
  createdAt                 DateTime                   @default(now())
  dateOfBirth               DateTime?
  gender                    String?
  managerId                 String?
  salutation                String?
  state                     String?
  updatedAt                 DateTime                   @updatedAt
  zipCode                   String?
  organizationId            String?
  shiftId                   String?
  assetRequests             AssetRequest[]
  assignedAssets            AssignedAsset[]
  attendance                Attendance[]
  attendanceCorrections     AttendanceCorrection[]
  attendanceRegularizations AttendanceRegularization[]
  auditLogs                 AuditLog[]
  bankDetails               BankDetails?
  assignedDevices           Device[]
  deviceIssues              DeviceIssue[]
  educationDetails          EducationCertification[]
  emergencyContacts         EmergencyContact[]
  department                Department                 @relation(fields: [departmentId], references: [id])
  manager                   User?                      @relation("Manager", fields: [managerId], references: [id])
  organization              Organization?              @relation(fields: [organizationId], references: [id])
  shift                     Shift?                     @relation(fields: [shiftId], references: [id])
  user                      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents                 EmployeeDocument[]
  skills                    EmployeeSkill[]
  expenseClaims             ExpenseClaim[]
  feedbacksReceived         Feedback[]                 @relation("FeedbackReceiver")
  goals                     Goal[]
  leaves                    LeaveRequest[]
  onboardingRecord          OnboardingRecord?
  payroll                   Payroll[]
  reviews                   PerformanceReview[]        @relation("Reviewee")
  personalInfo              PersonalInfo?
  promotions                Promotion[]
  lifecycleEvents           LifecycleEvent[]
  reimbursements            Reimbursement[]
  resignationRecord         Resignation?
  salaryRevisions           SalaryRevision[]
  salaryStructures          SalaryStructure[]
  selfAppraisals            SelfAppraisal[]
  surveyResponses           SurveyResponse[]
  taxDeclarations           TaxDeclaration[]
  trainingEnrollments       TrainingEnrollment[]
  workFromHome              WorkFromHome[]

  @@index([shiftId])
}

model PersonalInfo {
  id                  String   @id @default(cuid())
  employeeId          String   @unique
  nationality         String?
  bloodGroup          String?
  maritalStatus       String?
  fatherName          String?
  motherName          String?
  spouseName          String?
  childrenCount       Int?
  aadharNumber        String?
  panNumber           String?
  passportNumber      String?
  drivenLicenseNumber String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model EmergencyContact {
  id           String   @id @default(cuid())
  employeeId   String
  name         String
  relationship String
  phone        String
  email        String?
  address      String?
  createdAt    DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model BankDetails {
  id            String   @id @default(cuid())
  employeeId    String   @unique
  accountHolder String
  accountNumber String
  bankName      String
  branchName    String?
  ifscCode      String
  accountType   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model EducationCertification {
  id              String    @id @default(cuid())
  employeeId      String
  type            String
  institutionName String
  fieldOfStudy    String
  grade           String?
  startDate       DateTime
  endDate         DateTime?
  certificateUrl  String?
  createdAt       DateTime  @default(now())
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Attendance {
  id               String           @id @default(cuid())
  employeeId       String
  date             DateTime
  checkIn          DateTime?
  checkOut         DateTime?
  status           AttendanceStatus @default(PRESENT)
  biometricSync    Boolean          @default(false)
  createdAt        DateTime         @default(now())
  notes            String?
  workingHours     Float?
  checkInDeviceId  String?
  checkInLocation  Json?
  checkOutDeviceId String?
  checkOutLocation Json?
  isRegularized    Boolean          @default(false)
  overtimeApproved Boolean          @default(false)
  overtimeHours    Float            @default(0)
  shiftId          String?
  employee         Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift            Shift?           @relation(fields: [shiftId], references: [id])
  overtimeRecords  Overtime[]

  @@unique([employeeId, date])
  @@index([shiftId])
}

model WorkFromHome {
  id         String   @id @default(cuid())
  employeeId String
  date       DateTime
  reason     String?
  approvedBy String?
  status     String   @default("APPROVED")
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
}

model AttendanceCorrection {
  id                String            @id @default(cuid())
  employeeId        String
  date              DateTime
  originalCheckIn   DateTime?
  correctedCheckIn  DateTime?
  originalCheckOut  DateTime?
  correctedCheckOut DateTime?
  reason            String
  status            ApplicationStatus @default(DRAFT)
  approvedBy        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  rejectionReason   String?
  employee          Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model AttendanceRegularization {
  id               String            @id @default(cuid())
  employeeId       String
  date             DateTime
  reason           String
  missingDetails   String[]
  proposedCheckIn  DateTime?
  proposedCheckOut DateTime?
  status           ApplicationStatus @default(PENDING)
  approvedBy       String?
  approvedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  employee         Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model Shift {
  id                String        @id @default(cuid())
  name              String
  code              String        @unique
  description       String?
  startTime         String
  endTime           String
  breakDuration     Int           @default(30)
  gracePeriod       Int           @default(15)
  isFlexible        Boolean       @default(false)
  workingHours      Float         @default(8)
  overtimeEligible  Boolean       @default(true)
  nightShift        Boolean       @default(false)
  nightShiftStart   String?
  nightShiftEnd     String?
  applicableDays    Int[]         @default([1, 2, 3, 4, 5])
  organizationId    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  attendanceRecords Attendance[]
  employees         Employee[]
  organization      Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model LeaveRequest {
  id              String      @id @default(cuid())
  employeeId      String
  startDate       DateTime
  endDate         DateTime
  reason          String
  status          LeaveStatus @default(PENDING)
  approvedBy      String?
  createdAt       DateTime    @default(now())
  numberOfDays    Float
  rejectionReason String?
  updatedAt       DateTime    @updatedAt
  leaveType       LeaveType
  approver        User?       @relation("LeaveApprover", fields: [approvedBy], references: [id])
  employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model LeaveBalance {
  id            String    @id @default(cuid())
  employeeId    String
  leaveType     LeaveType
  totalDays     Float
  usedDays      Float     @default(0)
  remainingDays Float
  year          Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([employeeId, leaveType, year])
}

model Payroll {
  id                  String            @id @default(cuid())
  employeeId          String
  bonus               Decimal           @default(0) @db.Decimal(12, 2)
  netSalary           Decimal           @default(0) @db.Decimal(12, 2)
  month               String
  createdAt           DateTime          @default(now())
  status              String            @default("DRAFT")
  updatedAt           DateTime          @updatedAt
  absentDays          Int               @default(0)
  advanceDeduction    Decimal           @default(0) @db.Decimal(12, 2)
  approvedAt          DateTime?
  approvedBy          String?
  arrears             Decimal           @default(0) @db.Decimal(12, 2)
  basicSalary         Decimal           @default(0) @db.Decimal(12, 2)
  conveyanceAllowance Decimal           @default(0) @db.Decimal(12, 2)
  duplicateCheck      String            @default("")
  esiDeduction        Decimal           @default(0) @db.Decimal(12, 2)
  grossSalary         Decimal           @default(0) @db.Decimal(12, 2)
  halfDays            Float             @default(0)
  hra                 Decimal           @default(0) @db.Decimal(12, 2)
  incentive           Decimal           @default(0) @db.Decimal(12, 2)
  isBulkProcessed     Boolean           @default(false)
  isFinalSettlement   Boolean           @default(false)
  lateDays            Int               @default(0)
  leaveDays           Int               @default(0)
  leaveDeduction      Decimal           @default(0) @db.Decimal(12, 2)
  leaveEncashment     Decimal           @default(0) @db.Decimal(12, 2)
  loanDeduction       Decimal           @default(0) @db.Decimal(12, 2)
  medicalAllowance    Decimal           @default(0) @db.Decimal(12, 2)
  notes               String?
  otherAllowances     Decimal           @default(0) @db.Decimal(12, 2)
  otherDeductions     Decimal           @default(0) @db.Decimal(12, 2)
  otherEarnings       Decimal           @default(0) @db.Decimal(12, 2)
  overtimeHours       Float             @default(0)
  overtimePay         Decimal           @default(0) @db.Decimal(12, 2)
  paidAt              DateTime?
  paymentReference    String?
  pfDeduction         Decimal           @default(0) @db.Decimal(12, 2)
  presentDays         Int               @default(0)
  professionalTax     Decimal           @default(0) @db.Decimal(12, 2)
  rejectionReason     String?
  specialAllowance    Decimal           @default(0) @db.Decimal(12, 2)
  taxDeduction        Decimal           @default(0) @db.Decimal(12, 2)
  totalDeductions     Decimal           @default(0) @db.Decimal(12, 2)
  workingDays         Int               @default(0)
  year                Int               @default(2024)
  employee            Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollAuditLogs    PayrollAuditLog[]
  salaryRevision      SalaryRevision?

  @@index([employeeId])
  @@index([month])
  @@index([year])
  @@index([status])
}

model SalaryStructure {
  id                        String           @id @default(cuid())
  employeeId                String
  effectiveFrom             DateTime
  effectiveTo               DateTime?
  basicSalary               Decimal          @db.Decimal(12, 2)
  hra                       Decimal          @default(0) @db.Decimal(12, 2)
  specialAllowance          Decimal          @default(0) @db.Decimal(12, 2)
  conveyanceAllowance       Decimal          @default(0) @db.Decimal(12, 2)
  medicalAllowance          Decimal          @default(0) @db.Decimal(12, 2)
  otherAllowances           Decimal          @default(0) @db.Decimal(12, 2)
  hraPercentage             Float?
  pfPercentage              Float?
  esiApplicable             Boolean          @default(false)
  annualCTC                 Decimal          @db.Decimal(12, 2)
  variablePay               Decimal          @default(0) @db.Decimal(12, 2)
  approvedBy                String?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  salaryRevisionsAsNew      SalaryRevision[] @relation("NewStructure")
  salaryRevisionsAsPrevious SalaryRevision[] @relation("PreviousStructure")
  employee                  Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model SalaryRevision {
  id                  String          @id @default(cuid())
  employeeId          String
  payrollId           String?         @unique
  revisionType        String
  revisionDate        DateTime
  previousSalary      Decimal         @db.Decimal(12, 2)
  newSalary           Decimal         @db.Decimal(12, 2)
  revisionAmount      Decimal         @db.Decimal(12, 2)
  revisionPercentage  Float
  reason              String?
  effectiveFrom       DateTime
  approvedBy          String?
  remarks             String?
  previousStructureId String
  newStructureId      String
  createdAt           DateTime        @default(now())
  employee            Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  newStructure        SalaryStructure @relation("NewStructure", fields: [newStructureId], references: [id], map: "SalaryRevision_newStructureId_fkey")
  payroll             Payroll?        @relation(fields: [payrollId], references: [id])
  previousStructure   SalaryStructure @relation("PreviousStructure", fields: [previousStructureId], references: [id], map: "SalaryRevision_previousStructureId_fkey")

  @@index([employeeId])
  @@index([revisionDate])
}

model PayrollAuditLog {
  id              String   @id @default(cuid())
  payrollId       String
  action          String
  performedBy     String
  performedByName String
  previousValues  String?
  newValues       String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())
  payroll         Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([payrollId])
  @@index([action])
}

model TaxDeclaration {
  id                String   @id @default(cuid())
  employeeId        String
  financialYear     String
  oldRegimeBasic    Decimal  @default(0) @db.Decimal(12, 2)
  oldRegimeHRA      Decimal  @default(0) @db.Decimal(12, 2)
  oldRegimeLTA      Decimal  @default(0) @db.Decimal(12, 2)
  oldRegime80C      Decimal  @default(0) @db.Decimal(12, 2)
  oldRegime80D      Decimal  @default(0) @db.Decimal(12, 2)
  oldRegimeNPS      Decimal  @default(0) @db.Decimal(12, 2)
  oldRegimeOther    Decimal  @default(0) @db.Decimal(12, 2)
  newRegimeStandard Decimal  @default(50000) @db.Decimal(12, 2)
  newRegimeOther    Decimal  @default(0) @db.Decimal(12, 2)
  selectedRegime    String   @default("NEW")
  taxableIncome     Decimal  @default(0) @db.Decimal(12, 2)
  totalTax          Decimal  @default(0) @db.Decimal(12, 2)
  cess              Decimal  @default(0) @db.Decimal(12, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([financialYear])
}

model PayrollConfiguration {
  id                   String   @id @default(cuid())
  workingDaysPerMonth  Int      @default(26)
  workingDaysPerWeek   Int      @default(6)
  dailyHours           Float    @default(8)
  overtimeRate         Float    @default(2)
  unpaidLeaveDeduction Float    @default(1)
  halfDayDeduction     Float    @default(0.5)
  lateThreshold        Int      @default(3)
  lateDeductionDays    Int      @default(1)
  pfEmployeeRate       Float    @default(12)
  pfEmployerRate       Float    @default(12)
  pfMaxSalary          Decimal  @default(15000) @db.Decimal(12, 2)
  esiEmployeeRate      Float    @default(0.75)
  esiEmployerRate      Float    @default(3.25)
  esiMaxSalary         Decimal  @default(21000) @db.Decimal(12, 2)
  professionalTax      Decimal  @default(200) @db.Decimal(12, 2)
  tdsBasicExemption    Decimal  @default(300000) @db.Decimal(12, 2)
  tdsRebateLimit       Decimal  @default(500000) @db.Decimal(12, 2)
  bonusPercentage      Float    @default(8.33)
  bonusMinAmount       Decimal  @default(0) @db.Decimal(12, 2)
  lateFinePerDay       Decimal  @default(100) @db.Decimal(12, 2)
  requireApproval      Boolean  @default(true)
  autoApproveThreshold Decimal  @default(0) @db.Decimal(12, 2)
  noticePeriodDays     Int      @default(30)
  leaveEncashmentDays  Int      @default(30)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Reimbursement {
  id             String              @id @default(cuid())
  employeeId     String
  amount         Decimal             @db.Decimal(12, 2)
  category       String
  description    String
  receiptUrl     String?
  status         ReimbursementStatus @default(DRAFT)
  approvedBy     String?
  approvedAmount Decimal?            @db.Decimal(12, 2)
  paymentDate    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  employee       Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model ExpenseClaim {
  id          String              @id @default(cuid())
  employeeId  String
  projectCode String?
  amount      Decimal             @db.Decimal(12, 2)
  description String
  category    String
  submittedOn DateTime
  status      ReimbursementStatus @default(SUBMITTED)
  approvedBy  String?
  remarks     String?
  createdAt   DateTime            @default(now())
  employee    Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model PerformanceReview {
  id                  String   @id @default(cuid())
  employeeId          String
  reviewerId          String
  rating              Int
  feedback            String
  reviewDate          DateTime
  areasForImprovement String?
  createdAt           DateTime @default(now())
  reviewPeriodEnd     DateTime
  reviewPeriodStart   DateTime
  strengths           String?
  employee            Employee @relation("Reviewee", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer            User     @relation("Reviewer", fields: [reviewerId], references: [id])
}

model Goal {
  id          String   @id @default(cuid())
  employeeId  String
  createdBy   String
  title       String
  description String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("ACTIVE")
  progress    Int      @default(0)
  weight      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User     @relation("GoalCreator", fields: [createdBy], references: [id])
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model SelfAppraisal {
  id               String   @id @default(cuid())
  employeeId       String
  appraisalCycle   String
  selfRating       Int?
  achievements     String?
  challenges       String?
  learnings        String?
  improvementAreas String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Feedback {
  id         String   @id @default(cuid())
  receiverId String
  comments   String
  category   String
  visibility String   @default("PRIVATE")
  ratedOn    DateTime
  createdAt  DateTime @default(now())
  receiver   Employee @relation("FeedbackReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
}

model AssignedAsset {
  id             String      @id @default(cuid())
  employeeId     String
  assetName      String
  assetTag       String
  serialNumber   String
  description    String?
  assignmentDate DateTime
  returnDate     DateTime?
  status         AssetStatus @default(ACTIVE)
  condition      String?
  createdAt      DateTime    @default(now())
  employee       Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model AssetRequest {
  id            String            @id @default(cuid())
  employeeId    String
  assetType     String
  description   String
  justification String
  requestedDate DateTime
  status        ApplicationStatus @default(DRAFT)
  approvedBy    String?
  approvalDate  DateTime?
  createdAt     DateTime          @default(now())
  employee      Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Device {
  id             String        @id @default(cuid())
  assetName      String
  assetTag       String        @unique
  serialNumber   String        @unique
  description    String?
  status         DeviceStatus  @default(AVAILABLE)
  condition      String?
  assignedTo     String?
  assignedDate   DateTime?
  returnDate     DateTime?
  purchaseDate   DateTime?
  warrantyExpiry DateTime?
  vendor         String?
  cost           Decimal?      @db.Decimal(12, 2)
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  employee       Employee?     @relation(fields: [assignedTo], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  deviceIssues   DeviceIssue[]

  @@index([assignedTo])
  @@index([organizationId])
  @@index([status])
}

model DeviceIssue {
  id           String    @id @default(cuid())
  deviceId     String
  issue        String
  severity     String
  status       String    @default("open")
  reportedDate DateTime  @default(now())
  resolvedDate DateTime?
  resolvedBy   String?
  resolution   String?
  employeeId   String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  device       Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([employeeId])
  @@index([status])
}

model TrainingEnrollment {
  id               String   @id @default(cuid())
  employeeId       String
  trainingName     String
  trainingProvider String
  startDate        DateTime
  endDate          DateTime
  status           String   @default("ENROLLED")
  certificateUrl   String?
  cost             Decimal? @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model OnlineCourse {
  id          String   @id @default(cuid())
  name        String
  provider    String
  category    String
  duration    Int
  level       String
  description String?
  courseUrl   String?
  createdAt   DateTime @default(now())
}

model Announcement {
  id          String    @id @default(cuid())
  createdBy   String
  title       String
  content     String
  priority    String    @default("NORMAL")
  audience    String
  publishDate DateTime  @default(now())
  expiryDate  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  creator     User      @relation(fields: [createdBy], references: [id])
}

model CompanyNews {
  id              String   @id @default(cuid())
  title           String
  content         String
  imageUrl        String?
  publicationDate DateTime @default(now())
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model Notification {
  id        String               @id @default(cuid())
  userId    String
  type      NotificationType
  category  NotificationCategory @default(GENERAL)
  title     String
  message   String
  link      String?
  isRead    Boolean              @default(false)
  readAt    DateTime?
  createdAt DateTime             @default(now())
  expiresAt DateTime?
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
}

model Overtime {
  id              String            @id @default(cuid())
  attendanceId    String
  employeeId      String
  date            DateTime
  startTime       DateTime
  endTime         DateTime
  durationHours   Float
  rate            Float
  amount          Decimal           @db.Decimal(12, 2)
  reason          String?
  approvedBy      String?
  approvedAt      DateTime?
  status          ApplicationStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  attendance      Attendance        @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@index([employeeId])
  @@index([status])
}

model BiometricDevice {
  id             String        @id @default(cuid())
  name           String
